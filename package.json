{
  "name": "orionssh",
  "productName": "OrionSSH",
  "version": "2.0.0",
  "description": "Modern Electron SSH/SFTP client with xterm.js, tabs, split panes, themes, command presets and secure credential storage.",
  "author": "Equinox-e",
  "license": "MIT",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "npm run build:renderer && electron .",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vite build",
    "pack": "npm run build:renderer && electron-builder --dir",
    "build": "npm run build:renderer && electron-builder --win nsis portable",
    "build:portable": "npm run build:renderer && electron-builder --win portable",
    "build:installer": "npm run build:renderer && electron-builder --win nsis"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "serialport": "^13.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "dev.equinox.orionssh",
    "productName": "OrionSSH",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-renderer/**/*",
      "src/main/**/*",
      "assets/**/*",
      "contacts.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "contacts.json",
        "to": "contacts.json"
      }
    ],
    "win": {
      "icon": "assets/orionssh.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OrionSSH"
    }
  }
}